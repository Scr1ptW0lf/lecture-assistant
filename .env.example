# Set by install script — edit manually to change mode
MODE=full

# whisper model size: tiny, base, small
WHISPER_MODEL=base

# cuda or cpu
WHISPER_DEVICE=cuda

# float16 (GPU) or int8 (CPU)
WHISPER_COMPUTE_TYPE=float16

# Audio device index — -1 = auto-detect loopback
AUDIO_DEVICE_INDEX=-1

# Ollama (Full mode only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ChromaDB path — on Windows, change to avoid OneDrive sync issues:
# CHROMA_PATH=C:/Users/<you>/AppData/Local/lecture-assistant/chroma_db
CHROMA_PATH=./chroma_db
